# Supabase Configuration
# Get these values from: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3003
NODE_ENV=development

# Development Features (M1)
# Set to true to bypass authentication during development
NEXT_PUBLIC_DISABLE_AUTH=false

# Development Test User (optional - for quick testing)
# Create this user in Supabase Dashboard → Authentication → Users
DEV_TEST_EMAIL=dev@telopillo.test
DEV_TEST_PASSWORD=DevTest123

# M4: Semantic Search (Feature Flag)
# Set to 'true' to enable hybrid search (keyword + semantic)
# Requires HUGGINGFACE_API_KEY set in Supabase Edge Function secrets:
#   npx supabase secrets set HUGGINGFACE_API_KEY=hf_your_key_here
SEMANTIC_SEARCH_ENABLED=false
