# Supabase Configuration
# Get these values from: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3003
NODE_ENV=development

# Development Features (M1)
# Server-only flag. Set to true to bypass authentication during development.
# Production: MUST be false or unset. Middleware refuses bypass when NODE_ENV=production.
DISABLE_AUTH=false

# Development Test User (optional — for quick testing)
# Create this user in Supabase Dashboard → Authentication → Users, then fill in below.
DEV_TEST_EMAIL=
DEV_TEST_PASSWORD=

# Local/Docker Supabase: standard test password for test accounts (seller1@test.com, etc.)
# Set via: node scripts/set-test-passwords.mjs (uses SUPABASE_SERVICE_ROLE_KEY)
# Standard password: TestPassword123 (see tests/playwright-cli/README.md)

# M4: Semantic Search (Feature Flag)
# Set to 'true' to enable hybrid search (keyword + semantic)
# Requires HUGGINGFACE_API_KEY and ALLOWED_ORIGIN set in Supabase Edge Function secrets:
#   npx supabase secrets set HUGGINGFACE_API_KEY=hf_your_key_here
#   npx supabase secrets set ALLOWED_ORIGIN=http://localhost:3003 (dev)
#   npx supabase secrets set ALLOWED_ORIGIN=https://telopillo.bo (production)
SEMANTIC_SEARCH_ENABLED=false

# Site URL (used for OAuth redirects and CORS)
# In production, this should be your actual domain
NEXT_PUBLIC_SITE_URL=http://localhost:3003
